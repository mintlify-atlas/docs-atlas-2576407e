{
  "projectType": "saas",
  "projectName": "Hack4Impact Application Portal",
  "projectDescription": "A full-stack web application for Hack4Impact-UMD that streamlines the club membership application process — enabling applicants to apply for roles, reviewers to score submissions, and admins to manage the entire recruitment pipeline.",
  "theme": "almond",
  "primaryColor": "#1d70bd",
  "lightColor": "#83d3cc",
  "darkColor": null,
